{
    "compilerOptions": {
        "target": "es5",
        "module": "none",
        "outFile": "../public/app.js",
        "sourceRoot": "./sketch",
        "rootDir": "./sketch",
        "sourceMap": true,

        "removeComments": true,
        "preserveConstEnums": true,
        "noImplicitAny": true,
        "strict": true,
        "strictPropertyInitialization": true,
        "strictNullChecks": true
    },
    "exclude": [
        "./node_modules",
        "./build",
        "./assets"
    ]
}